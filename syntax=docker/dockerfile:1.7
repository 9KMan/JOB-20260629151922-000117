# syntax=docker/dockerfile:1.7
FROM mcr.microsoft.com/playwright/python:v1.49.1-jammy

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PATH="/app:${PATH}" \
    PIP_NO_CACHE_DIR=1 \
    PIP_DISABLE_PIP_VERSION_CHECK=1

WORKDIR /app

# Install Python deps first for layer caching
COPY requirements.txt ./
RUN pip install --no-cache-dir -r requirements.txt

# Install Playwright browsers (already in base image, but ensure deps)
# Base image already includes Chromium; skip reinstall to save space.

# Copy source
COPY pyproject.toml ./
COPY src ./src
COPY alembic ./alembic
COPY alembic.ini ./
COPY README.md ./

# Install the package itself
RUN pip install --no-cache-dir -e .

EXPOSE 8000

# Default command runs API; docker-compose overrides for scheduler / cli
CMD ["uvicorn", "bpa.main:app", "--host", "0.0.0.0", "--port", "8000"]
